{
  "name": "deadshock",
  "version": "1.0.0",
  "description": "Triggers PiShock devices based on Deadlock events",
  "main": "dist/browser/index.js",
  "author": {
    "name": "SharkGirlCass"
  },
  "license": "MIT",
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "build": {
    "nodeGypRebuild": false,
    "appId": "com.deadshock.app",
    "asar": true,
    "overwolf": {
      "disableAdOptimization": true
    },
    "extraResources": [{
      "from": "dist/python/",
      "to": "python/",
      "filter": ["*.exe", "event_handler"]
    }],
    "productName": "DeadShock",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "*.js",
      "*.html",
      "*.exe"
    ],
    "copyright": "",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "legalTrademarks": ""
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "DeadShock",
      "allowElevation": true,
      "perMachine": true
    }
  },
  "scripts": {
    "build:renderer": "webpack --config ./webpack.renderer.config.js",
    "build:main": "webpack --config ./webpack.main.config.js",
    "build": "webpack --mode=development && npm run build:main && npm run build:renderer",
    "build:dev": "webpack --watch --mode=development",
    "build:start": "npm run build && ow-electron . ",
    "start": "ow-electron .",
    "build:python": "pyinstaller --onefile --distpath ./dist/python --name event_handler ./python/event_handler.py",
    "build:ow-electron": "npm run build && npm run build:python && ow-electron-builder --c.extraMetadata.name=GameEventsTester --publish=never"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "latest",
    "@overwolf/ow-electron-builder": "latest",
    "@overwolf/ow-electron-packages-types": "^0.0.5",
    "@types/jquery": "^3.5.16",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.11.18",
    "copy-webpack-plugin": "^11.0.0",
    "electron": "21.1.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "jest-junit": "^15.0.0",
    "jest-mock-extended": "^3.0.1",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.0.3",
    "ts-loader": "^9.4.2",
    "typescript": "^4.7.4",
    "typescript-logging": "^2.0.2",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "wrapper-webpack-plugin": "^2.1.0"
  }
}
